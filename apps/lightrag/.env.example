OPENAI_API_KEY="sk-..."

# --- PostgreSQL Configuration (AWS Aurora IAM Auth) ---
AWS_REGION="us-east-1"
POSTGRES_HOST="kompany.cluster-cml688qeuggm.us-east-1.rds.amazonaws.com"
POSTGRES_PORT="5432"
POSTGRES_USER="postgres"
